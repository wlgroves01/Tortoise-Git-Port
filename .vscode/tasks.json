{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build active C++ file",
      "type": "shell",
      "command": "clang++",
      "args": [
        "-std=c++20",
        "-O3",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Generated task to build the active C++ file"
    }
  ]
}
