build src/Git/libgit-wrapper.so: CXX_SHARED_LIBRARY_LINKER__git-wrapper_Debug src/Git/CMakeFiles/git-wrapper.dir/Git.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitAdminDir.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitDataObject.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitFolderStatus.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitIndex.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitMailmap.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitPatch.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitRev.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitRevLoglist.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitRevRefBrowser.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitStatus.cpp.o src/Git/CMakeFiles/git-wrapper.dir/GitStatusListCtrl.cpp.o src/Git/CMakeFiles/git-wrapper.dir/MassiveGitTaskBase.cpp.o src/Git/CMakeFiles/git-wrapper.dir/TGitPath.cpp.o
  CONFIG = Debug
  DEP_FILE = src/Git/CMakeFiles/git-wrapper.dir/link.d
  LANGUAGE_COMPILE_FLAGS = -g
  LINK_FLAGS = -shared -Xlinker --dependency-file=src/Git/CMakeFiles/git-wrapper.dir/link.d
  OBJECT_DIR = src/Git/CMakeFiles/git-wrapper.dir
  POST_BUILD = :
  PRE_LINK = :
  SONAME = libgit-wrapper.so
  SONAME_FLAG = -Wl,-soname,
  TARGET_FILE = src/Git/libgit-wrapper.so
  TARGET_PDB = git-wrapper.so.dbg
  TARGET_SUPPORT_DIR = src/Git/CMakeFiles/git-wrapper.dir


#############################################
# Utility command for edit_cache

build src/Git/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/wyattg/CodingProjects/tortoise-git/TortoiseGit/build/src/Git && /usr/bin/ccmake -S/home/wyattg/CodingProjects/tortoise-git/TortoiseGit -B/home/wyattg/CodingProjects/tortoise-git/TortoiseGit/build
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build src/Git/edit_cache: phony src/Git/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build src/Git/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/wyattg/CodingProjects/tortoise-git/TortoiseGit/build/src/Git && /usr/bin/cmake --regenerate-during-build -S/home/wyattg/CodingProjects/tortoise-git/TortoiseGit -B/home/wyattg/CodingProjects/tortoise-git/TortoiseGit/build
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build src/Git/rebuild_cache: phony src/Git/CMakeFiles/rebuild_cache.util

# =============================================================================
# Target aliases.

build git-wrapper: phony src/Git/libgit-wrapper.so

build libgit-wrapper.so: phony src/Git/libgit-wrapper.so

